# ─── Server ───────────────────────────────────────
PORT=3001

# ─── Meshulam (Payment Gateway) ──────────────────
# Get these from https://meshulam.co.il/dashboard
MESHULAM_API_KEY=your_meshulam_api_key_here
MESHULAM_TERMINAL=your_terminal_id_here

# Set to "true" for sandbox testing, "false" for live
MESHULAM_SANDBOX=true

# ─── Notifications (optional) ────────────────────
# Owner's phone for WhatsApp/SMS alerts
OWNER_PHONE=+972501234567
